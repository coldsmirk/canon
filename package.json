{
  "name": "canon",
  "version": "0.2.0",
  "private": true,
  "description": "Opinionated, shared frontend toolchain configs published under @coldsmirk/*.",
  "homepage": "https://github.com/coldsmirk/canon#readme",
  "bugs": "https://github.com/coldsmirk/canon/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coldsmirk/canon.git"
  },
  "license": "MIT",
  "author": {
    "name": "Venus"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "inspect": "eslint --inspect-config",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm -r run typecheck",
    "version:major": "jiti scripts/version.ts major",
    "version:minor": "jiti scripts/version.ts minor",
    "version:patch": "jiti scripts/version.ts patch"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,md,css}": "eslint --fix"
  },
  "devDependencies": {
    "@coldsmirk/commitlint-config": "workspace:*",
    "@coldsmirk/eslint-config": "workspace:*",
    "@coldsmirk/tsconfig": "workspace:*",
    "@commitlint/cli": "^21.0.2",
    "@types/node": "^24.13.2",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  }
}
