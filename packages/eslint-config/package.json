{
  "name": "@coldsmirk/eslint-config",
  "version": "0.2.3",
  "description": "Opinionated, sealed ESLint flat config for pure-TypeScript and React projects.",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "flat-config",
    "eslint-flat-config"
  ],
  "homepage": "https://github.com/coldsmirk/canon/tree/main/packages/eslint-config#readme",
  "bugs": "https://github.com/coldsmirk/canon/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coldsmirk/canon.git",
    "directory": "packages/eslint-config"
  },
  "license": "MIT",
  "author": {
    "name": "Venus"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint-react/eslint-plugin": "^5.9.0",
    "@eslint-react/kit": "5.9.1",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-plugin-antfu": "^3.2.3",
    "eslint-plugin-import-lite": "^0.6.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-package-json": "^1.5.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-dom": "^5.9.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-naming-convention": "^5.9.0",
    "eslint-plugin-react-web-api": "^5.9.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^65.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsonc-eslint-parser": "^3.1.0",
    "typescript-eslint": "^8.61.0"
  },
  "devDependencies": {
    "eslint": "^10.4.1"
  },
  "peerDependencies": {
    "eslint": ">=10"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
